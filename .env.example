# Vertex AI バックエンドを使用（1 に設定すると ADK が Vertex AI 経由で Gemini を呼ぶ）
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

GEMINI_MODEL=gemini-2.0-flash

# デモアプリのソースコードを格納した GCS バケット名
# gs://<GCS_BUCKET>/<system-name>/ 以下にソースコードを置く
# 例: gs://rtg-demo-sources/system-m/index.html
GCS_BUCKET=rtg-demo-sources

# RTG 本体が 8000 を使用するため 8001 推奨
PORT=8001
